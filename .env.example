# Grand River Advisory (GRA) — environment template.
# Copy to .env or .env.local for local dev. NEVER commit real secrets or keys.

# ─── Site origin ─────────────────────────────────────────────────────────────
# Production origin. When set to a real origin, the site is treated as
# domain-confirmed: pages drop the noindex meta and the post-build SEO step
# emits an allow + sitemap robots.txt. Confirmed domain: graadvisory.com.
NEXT_PUBLIC_SITE_URL=https://graadvisory.com

# Optional explicit confirmation override. Confirmation is primarily driven by
# the presence of NEXT_PUBLIC_SITE_URL above; set this to `false` to force the
# site back into a noindex / crawl-blocked state without clearing the URL.
NEXT_PUBLIC_DOMAIN_CONFIRMED=true

# ─── Analytics (optional) ───────────────────────────────────────────────────
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Empty = disabled.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
