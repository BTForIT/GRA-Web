# Grand River (GRA) — environment template.
# Copy to .env.local for local dev. NEVER commit real secrets or API keys.

# ─── Site origin (set before production deploy) ──────────────────────────────
# Grand River's production domain is a Namecheap domain that is NOT yet
# confirmed. Set this to the full origin once known, e.g.
#   NEXT_PUBLIC_SITE_URL=https://www.<confirmed-domain>
# Until set, the build falls back to a non-resolving .invalid placeholder and
# marks pages noindex + emits a crawl-blocking robots.txt.
NEXT_PUBLIC_SITE_URL=

# ─── Analytics (optional) ───────────────────────────────────────────────────
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Empty = disabled.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
